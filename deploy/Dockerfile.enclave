FROM public.ecr.aws/amazonlinux/amazonlinux:2023-minimal

RUN dnf install -y python3 iproute && dnf clean all

# Built from this repo: cargo build --release --bin aw
COPY aw-bin /usr/local/bin/attested-workload

# Optional demo workload (app-proxy forwards /v1/* and /healthz here)
COPY examples/hello-workload.py /app/hello-workload.py
COPY examples/eif-entry.sh /entry.sh
# Build context must be repo root (see deploy/nitro-deploy.sh).
RUN chmod +x /entry.sh

CMD ["/entry.sh"]
